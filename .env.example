# UPT Pontaje - Environment Variables
# Copy this file to .env and fill in the values

# Database
DB_PASSWORD=pontaje_pass

# JWT Secret (generate a secure random string for production)
JWT_SECRET=bXlTdXBlclNlY3JldEtleUZvclByb2R1Y3Rpb24xMjM0NTY3ODkw

# Mail Configuration
# IMPLICIT: lasă gol → se folosește MailHog (server SMTP de test, UI pe http://localhost:8025)
# Pentru Gmail REAL, decomentează și completează:
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=adresa_ta@gmail.com
# MAIL_PASSWORD=app_password_16_caractere
# MAIL_SMTP_AUTH=true
# MAIL_SMTP_STARTTLS=true
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=
MAIL_SMTP_STARTTLS=

# Destinatar implicit pentru raportul centralizat (precompletat în câmpul To)
REPORT_DEFAULT_RECIPIENT=

# Asistent AI (Groq — gratuit). Obține o cheie de pe https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# CORS Origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
